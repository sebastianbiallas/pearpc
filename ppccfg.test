## PearPC Test Configuration
## Download Mandrake 9.1 PPC CD1 from:
##   https://archive.org/details/MandrakeLinux9.1ppc
## and place it as MandrakeLinux-9.1-CD1.ppc.iso next to this file.

ppc_start_resolution = "800x600x15"
ppc_start_full_screen = 0
redraw_interval_msec = 40

key_compose_dialog = "F11"
key_change_cd_0 = "none"
key_toggle_mouse_grab = "F12"
key_toggle_full_screen = "Alt+Return"

prom_bootmethod = "auto"
prom_env_machargs = "-v"
prom_driver_graphic = "video.x"

## Boot directly from CD (no hard disk)
pci_ide0_master_installed = 1
pci_ide0_master_image = "MandrakeLinux-9.1-CD1.ppc.iso"
pci_ide0_master_type = "cdrom"

pci_ide0_slave_installed = 0

pci_3c90x_installed = 0
pci_rtl8139_installed = 0
pci_usb_installed = 1
pci_serial_installed = 0

nvram_file = "nvram"
